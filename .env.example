# ─── Banco de dados (Turso / libSQL) ───────────────────────────────
# LOCAL (dev): SQLite via arquivo
DATABASE_URL="file:./db/custom.db"
# DATABASE_AUTH_TOKEN não é necessário para file local (deixe vazio/comentado)

# PRODUÇÃO (Vercel): Turso libSQL over HTTP
# 1. Crie um DB em https://turso.tech → "Create database"
# 2. Rode localmente: turso db shell <nome> < prisma/schema-init.sql  (ou bun run db:push com a URL de produção)
# 3. No Vercel, defina:
# DATABASE_URL="libsql://<seu-db>.turso.io"
# DATABASE_AUTH_TOKEN="<seu-token-turso>"

# ─── MisticPay (PIX) ───────────────────────────────────────────────
MISTICPAY_CLIENT_ID=seu_client_id
MISTICPAY_CLIENT_SECRET=seu_client_secret
MISTICPAY_WEBHOOK_URL=https://gta6.xdeals.online/webhook
